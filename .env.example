# Copy to .env (or .env.local / .env.production) and fill in real values.
# This file is the ONLY tracked env file — it must contain NO real secrets.

SECRET_KEY=change-me-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=3

# Must include ?charset=utf8mb4 to avoid Korean/CJK corruption
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/dbname?charset=utf8mb4

# QR
QR_CODE_VALIDITY_MINUTES=5

# push notification
# Shared secret with LMS. Caller sends it as the X-API-Key header.
# Leave empty to disable API-key auth (admin JWT still works).
LMS_API_KEY=
